{
  "name": "@tools-aoeur/eslint-config",
  "version": "4.1.0",
  "description": "Shared ESLint config for @tools-aoeur projects.",
  "main": "src/index.js",
  "license": "MIT",
  "author": "@tools-aoeur",
  "homepage": "https://github.com/tools-aoeur/eslint-config",
  "scripts": {
    "lint": "npm run lint:eslint && npm run lint:prettier && npm run lint:tsc",
    "lint:eslint": "eslint src",
    "lint:prettier": "prettier --check src",
    "lint:tsc": "tsc --project tsconfig.self.json",
    "prepublish": "npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tools-aoeur/eslint-config.git"
  },
  "keywords": [
    "eslint",
    "eslintconfig"
  ],
  "type": "module",
  "files": [
    "src",
    ".prettierrc.json",
    "tsconfig.json"
  ],
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/utils": "^8.58.1",
    "@vitest/eslint-plugin": "^1.6.15",
    "confusing-browser-globals": "^1.0.11",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-lodash": "^8.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript-eslint": "^8.58.1"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/confusing-browser-globals": "^1.0.3",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
